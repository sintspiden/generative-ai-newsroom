---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsItem from '../../../components/NewsItem.astro';
import { getCategoryMap, slugify } from '../../../lib/news';

export async function getStaticPaths() {
  const categoryMap = await getCategoryMap();
  return Array.from(categoryMap.entries()).map(([category, items]) => ({
    params: { slug: slugify(category) },
    props: { category, items },
  }));
}

const { category, items } = Astro.props;
---

<BaseLayout title={`Category: ${category}`}>
  <section class="panel" style="margin:1rem 0">
    <h1 style="margin:.1rem 0 .2rem">Category: {category}</h1>
    <p class="muted" style="margin:0">{items.length} items</p>
  </section>
  <div class="feed">{items.map((item) => <NewsItem item={item} />)}</div>
</BaseLayout>
