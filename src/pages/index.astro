---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsItem from '../components/NewsItem.astro';
import { getCategoryMap, getLatestDayItems, getMonthlyMap, getSourceMap, slugify } from '../lib/news';

const { latestDay, items } = await getLatestDayItems();
const categoryMap = await getCategoryMap();
const sourceMap = await getSourceMap();
const monthlyMap = await getMonthlyMap();
const sourcesToday = new Set(items.map((item) => item.data.source).filter(Boolean));
const frontpageCategories = Array.from(new Set(items.map((item) => item.data.category))).sort((a, b) => a.localeCompare(b));
const defaultCategory = frontpageCategories[0] ?? '';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Generative AI Newsroom">
  <section class="panel" style="margin:1rem 0">
    <strong>Latest available date:</strong>
    {latestDay ? new Date(latestDay).toLocaleDateString('en-CA', { dateStyle: 'full' }) : 'No data found'}
    {latestDay && <span class="muted"> · {items.length} items · {sourcesToday.size} sources</span>}
  </section>

  <div class="main">
    <section>
      <h2 style="margin-top:0">Latest feed</h2>
      {frontpageCategories.length > 0 && (
        <div id="category-tabs" style="display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:.8rem">
          {frontpageCategories.map((category) => (
            <button
              type="button"
              class="tab-btn"
              data-category={category}
              aria-pressed={category === defaultCategory ? 'true' : 'false'}
            >
              {category}
            </button>
          ))}
        </div>
      )}
      <div class="feed" id="frontpage-feed">
        {items.length ? items.map((item) => (
          <div data-feed-category={item.data.category}>
            <NewsItem item={item} />
          </div>
        )) : <p class="muted">No content items found.</p>}
      </div>
    </section>

    <aside class="panel">
      <h3 id="categories">Categories</h3>
      <ul>
        {Array.from(categoryMap.entries()).map(([category, entries]) => (
          <li><a href={`${base}category/${slugify(category)}/`}>{category}</a> <span class="muted">({entries.length})</span></li>
        ))}
      </ul>

      <h3>Recent archive months</h3>
      <ul>
        {Array.from(monthlyMap.entries()).sort((a,b)=> b[0].localeCompare(a[0])).slice(0, 8).map(([month, days]) => {
          const [year, mm] = month.split('-');
          return <li><a href={`${base}archive/${year}/${mm}/`}>{month}</a> <span class="muted">({days.length} days)</span></li>;
        })}
      </ul>

      {sourceMap.size > 0 && (
        <>
          <h3>Sources</h3>
          <ul>
            {Array.from(sourceMap.entries()).slice(0, 10).map(([source, entries]) => (
              <li><a href={`${base}source/${slugify(source)}/`}>{source}</a> <span class="muted">({entries.length})</span></li>
            ))}
          </ul>
        </>
      )}
    </aside>
  </div>

  <script is:inline>
    const tabButtons = Array.from(document.querySelectorAll('.tab-btn'));
    const feedItems = Array.from(document.querySelectorAll('#frontpage-feed > [data-feed-category]'));

    function applyCategory(category) {
      feedItems.forEach((el) => {
        const matches = el.getAttribute('data-feed-category') === category;
        el.style.display = matches ? '' : 'none';
      });
      tabButtons.forEach((btn) => {
        const active = btn.getAttribute('data-category') === category;
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
    }

    tabButtons.forEach((btn) => {
      btn.addEventListener('click', () => applyCategory(btn.getAttribute('data-category')));
    });

    if (tabButtons.length > 0) {
      applyCategory(tabButtons[0].getAttribute('data-category'));
    }
  </script>
</BaseLayout>
