---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getMonthlyMap } from '../../../../lib/news';

export async function getStaticPaths() {
  const monthlyMap = await getMonthlyMap();
  return Array.from(monthlyMap.entries()).map(([month, days]) => {
    const [year, mm] = month.split('-');
    return { params: { year, month: mm }, props: { month, days } };
  });
}

const { month, days } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`Archive ${month}`}>
  <section class="panel" style="margin:1rem 0">
    <h1 style="margin:.1rem 0 .2rem">Archive {month}</h1>
    <p class="muted" style="margin:0">Daily breakdown for this month.</p>
  </section>

  <div class="feed">
    {days.map(({ day, count }) => {
      const [year, mm, dd] = day.split('-');
      return (
        <sl-card class="item-card">
          <h3 style="margin:.1rem 0 .35rem"><a href={`${base}archive/${year}/${mm}/${dd}/`}>{day}</a></h3>
          <p class="muted" style="margin:0">{count} items</p>
        </sl-card>
      );
    })}
  </div>
</BaseLayout>
