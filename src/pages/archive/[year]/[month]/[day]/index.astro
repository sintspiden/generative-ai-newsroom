---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import NewsItem from '../../../../../components/NewsItem.astro';
import { getDayMap } from '../../../../../lib/news';

export async function getStaticPaths() {
  const dayMap = await getDayMap();
  return Array.from(dayMap.entries()).map(([day, items]) => {
    const [year, month, d] = day.split('-');
    return { params: { year, month, day: d }, props: { day, items } };
  });
}

const { day, items } = Astro.props;
---

<BaseLayout title={`Archive ${day}`}>
  <section class="panel" style="margin:1rem 0">
    <h1 style="margin:.1rem 0 .2rem">{day}</h1>
    <p class="muted" style="margin:0">{items.length} items</p>
  </section>
  <div class="feed">{items.map((item) => <NewsItem item={item} />)}</div>
</BaseLayout>
