---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMonthlyMap } from '../../lib/news';

const monthlyMap = await getMonthlyMap();
const months = Array.from(monthlyMap.entries()).sort((a, b) => b[0].localeCompare(a[0]));
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Archive">
  <section class="panel" style="margin:1rem 0">
    <h1 style="margin:.1rem 0 .2rem">Archive</h1>
    <p class="muted" style="margin:0">Browse month-by-month newsroom history.</p>
  </section>

  <div class="feed">
    {months.map(([month, days]) => {
      const [year, mm] = month.split('-');
      return (
        <sl-card class="item-card">
          <h3 style="margin:.1rem 0 .35rem"><a href={`${base}archive/${year}/${mm}/`}>{month}</a></h3>
          <p class="muted" style="margin:0">{days.length} publishing days</p>
        </sl-card>
      );
    })}
  </div>
</BaseLayout>
