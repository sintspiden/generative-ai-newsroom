---
const { title = 'Generative AI Newsroom' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.1/cdn/themes/dark.css" />
    <style>
      body { margin: 0; font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: radial-gradient(1200px 500px at 20% -10%, #312e81 0%, #0b1020 42%, #070b16 100%); color: #e6edf8; }
      header { border-bottom: 1px solid #26314a; background: rgba(10, 14, 26, .72); backdrop-filter: blur(8px); position: sticky; top: 0; z-index: 10; }
      .container { max-width: 1120px; margin: 0 auto; padding: 1rem; }
      .header-inner { display: flex; gap: 1rem; justify-content: space-between; align-items: center; }
      .brand { font-weight: 800; text-decoration: none; color: #f8fbff; letter-spacing: .2px; }
      nav { display: flex; gap: .5rem; flex-wrap: wrap; }
      nav a { text-decoration: none; color: #b7c4dd; font-size: .92rem; padding: .35rem .6rem; border-radius: .5rem; }
      nav a:hover { background: #1f2a44; color: #8ab4ff; }
      .main { display: grid; gap: 1rem; grid-template-columns: 1fr; }
      .panel { background: #0f1729; border: 1px solid #273249; border-radius: .9rem; padding: .95rem; box-shadow: 0 10px 28px rgba(0,0,0,.35); }
      .muted { color: #97a7c4; }
      .feed { display: grid; gap: .8rem; }
      .item-card::part(base) { border-radius: .95rem; border: 1px solid #2a3550; background: linear-gradient(180deg, #111b31 0%, #0d1628 100%); box-shadow: 0 12px 30px rgba(0,0,0,.32); }
      .item h3 { margin: .15rem 0 .35rem; font-size: 1.05rem; }
      .item h3 a { color: #dbe7ff; text-decoration: none; }
      .item h3 a:hover { color: #9cc2ff; }
      .item p { margin: .35rem 0; }
      .item a { color: #8fb6ff; }
      .item a:hover { color: #bad3ff; }
      sl-badge::part(base) { background: rgba(99, 102, 241, .22); color: #c7d2fe; border: 1px solid #4f46e5; }
      sl-tab-group::part(base) { background: #0f1729; border: 1px solid #2a3550; border-radius: .95rem; padding: .45rem .45rem .85rem; box-shadow: 0 10px 24px rgba(0,0,0,.28); }
      sl-tab-group::part(nav) { padding: .2rem .2rem .55rem; border-bottom: 1px solid #25324a; }
      sl-tab::part(base) { border-radius: .65rem; color: #a7b6d4; }
      sl-tab[active]::part(base) { background: linear-gradient(90deg, rgba(79,70,229,.30), rgba(14,165,233,.24)); color: #dbeafe; font-weight: 600; border: 1px solid #4f46e5; }
      sl-tab-panel::part(base) { padding-top: .6rem; }
      @media (min-width: 900px) { .main { grid-template-columns: 2.1fr .9fr; } }
    </style>
    <script type="module" src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.1/cdn/shoelace-autoloader.js"></script>
  </head>
  <body>
    <header>
      <div class="container header-inner">
        <a class="brand" href={`${base}`}>Generative AI Newsroom</a>
        <nav>
          <a href={`${base}#categories`}>Categories</a>
          <a href={`${base}archive/`}>Archive</a>
          <a href={`${base}search/`}>Search</a>
        </nav>
      </div>
    </header>
    <div class="container"><slot /></div>
  </body>
</html>
