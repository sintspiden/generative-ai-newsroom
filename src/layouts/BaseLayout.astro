---
const { title = 'Generative AI Newsroom' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      :root { --fg: #121417; --muted: #5f6773; --line: #e6e8eb; --pill: #eef3ff; --bg: #fafbfd; }
      body { margin: 0; font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif; color: var(--fg); background: var(--bg); }
      a { color: inherit; }
      .container { max-width: 1120px; margin: 0 auto; padding: 1rem; }
      header { border-bottom: 1px solid var(--line); background: white; position: sticky; top: 0; z-index: 10; }
      .header-inner { display: flex; gap: 1rem; justify-content: space-between; align-items: center; }
      nav { display: flex; gap: .8rem; flex-wrap: wrap; font-size: .95rem; }
      .brand { font-weight: 700; text-decoration: none; }
      .main { display: grid; gap: 1.25rem; grid-template-columns: 1fr; }
      .panel { background: white; border: 1px solid var(--line); border-radius: .7rem; padding: .9rem; }
      .muted { color: var(--muted); }
      .pill { display: inline-block; background: var(--pill); border-radius: 999px; padding: .2rem .55rem; font-size: .78rem; margin-right: .4rem; }
      .tab-btn { border: 1px solid var(--line); background: white; border-radius: 999px; padding: .35rem .8rem; font-size: .9rem; cursor: pointer; }
      .tab-btn[aria-pressed='true'] { background: var(--pill); border-color: #c9d7ff; font-weight: 600; }
      .feed { display: grid; gap: .75rem; }
      .item h3 { margin: .2rem 0 .4rem; font-size: 1.03rem; }
      .item p { margin: .35rem 0; }
      @media (min-width: 900px) { .main { grid-template-columns: 2.1fr .9fr; } }
    </style>
  </head>
  <body>
    <header>
      <div class="container header-inner">
        <a class="brand" href={`${base}`}>Generative AI Newsroom</a>
        <nav>
          <a href={`${base}#categories`}>Categories</a>
          <a href={`${base}archive/`}>Archive</a>
          <a href={`${base}search/`}>Search</a>
        </nav>
      </div>
    </header>
    <div class="container"><slot /></div>
  </body>
</html>
