---
const { title = 'Generative AI Newsroom' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.1/cdn/themes/light.css" />
    <style>
      body { margin: 0; font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #f4f6fa; color: #0f172a; }
      header { border-bottom: 1px solid #e5e7eb; background: #fff; position: sticky; top: 0; z-index: 10; }
      .container { max-width: 1120px; margin: 0 auto; padding: 1rem; }
      .header-inner { display: flex; gap: 1rem; justify-content: space-between; align-items: center; }
      .brand { font-weight: 800; text-decoration: none; color: #0f172a; }
      nav { display: flex; gap: .5rem; flex-wrap: wrap; }
      nav a { text-decoration: none; color: #334155; font-size: .92rem; padding: .35rem .6rem; border-radius: .5rem; }
      nav a:hover { background: #eef2ff; color: #1e40af; }
      .main { display: grid; gap: 1rem; grid-template-columns: 1fr; }
      .panel { background: #fff; border: 1px solid #e5e7eb; border-radius: .85rem; padding: .9rem; }
      .muted { color: #64748b; }
      .feed { display: grid; gap: .8rem; }
      .item-card::part(base) { border-radius: .9rem; border: 1px solid #e6eaf2; box-shadow: 0 8px 24px rgba(15, 23, 42, .04); }
      .item h3 { margin: .15rem 0 .35rem; font-size: 1.05rem; }
      .item p { margin: .35rem 0; }
      sl-tab-group::part(base) { background: #fff; border: 1px solid #e5e7eb; border-radius: .9rem; padding: .4rem .4rem .8rem; }
      sl-tab-group::part(nav) { padding: .2rem .2rem .5rem; border-bottom: 1px solid #e8edf5; }
      sl-tab::part(base) { border-radius: .6rem; }
      sl-tab-panel::part(base) { padding-top: .55rem; }
      @media (min-width: 900px) { .main { grid-template-columns: 2.1fr .9fr; } }
    </style>
    <script type="module" src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.1/cdn/shoelace-autoloader.js"></script>
  </head>
  <body>
    <header>
      <div class="container header-inner">
        <a class="brand" href={`${base}`}>Generative AI Newsroom</a>
        <nav>
          <a href={`${base}#categories`}>Categories</a>
          <a href={`${base}archive/`}>Archive</a>
          <a href={`${base}search/`}>Search</a>
        </nav>
      </div>
    </header>
    <div class="container"><slot /></div>
  </body>
</html>
