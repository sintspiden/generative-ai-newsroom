---
const { title = 'Generative AI Newsroom' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.1/cdn/themes/light.css" />
    <style>
      body { margin: 0; font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #f1f3f7; color: #0b1220; }
      header { border-bottom: 1px solid #dbe2f0; background: rgba(255,255,255,.85); backdrop-filter: blur(8px); position: sticky; top: 0; z-index: 10; }
      .container { max-width: 1120px; margin: 0 auto; padding: 1rem; }
      .header-inner { display: flex; gap: 1rem; justify-content: space-between; align-items: center; }
      .brand { font-weight: 800; text-decoration: none; color: #0f172a; letter-spacing: .2px; }
      nav { display: flex; gap: .5rem; flex-wrap: wrap; }
      nav a { text-decoration: none; color: #334155; font-size: .92rem; padding: .35rem .6rem; border-radius: .5rem; }
      nav a:hover { background: #e0e7ff; color: #3730a3; }
      .main { display: grid; gap: 1rem; grid-template-columns: 1fr; }
      .panel { background: #ffffff; border: 1px solid #dbe4f3; border-radius: .9rem; padding: .95rem; box-shadow: 0 8px 22px rgba(30, 41, 59, .05); }
      .muted { color: #5b6b83; }
      .feed { display: grid; gap: .8rem; }
      .item-card::part(base) { border-radius: .95rem; border: 1px solid #dde6f5; background: #ffffff; box-shadow: 0 10px 28px rgba(37, 99, 235, .06); }
      .item h3 { margin: .15rem 0 .35rem; font-size: 1.05rem; }
      .item p { margin: .35rem 0; }
      sl-tab-group::part(base) { background: #ffffff; border: 1px solid #dbe4f3; border-radius: .95rem; padding: .45rem .45rem .85rem; box-shadow: 0 10px 24px rgba(30, 41, 59, .04); }
      sl-tab-group::part(nav) { padding: .2rem .2rem .55rem; border-bottom: 1px solid #e6ecf8; }
      sl-tab::part(base) { border-radius: .65rem; color: #334155; }
      sl-tab[active]::part(base) { background: #e0e7ff; color: #312e81; font-weight: 600; }
      sl-tab-panel::part(base) { padding-top: .6rem; }
      @media (min-width: 900px) { .main { grid-template-columns: 2.1fr .9fr; } }
    </style>
    <script type="module" src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.15.1/cdn/shoelace-autoloader.js"></script>
  </head>
  <body>
    <header>
      <div class="container header-inner">
        <a class="brand" href={`${base}`}>Generative AI Newsroom</a>
        <nav>
          <a href={`${base}#categories`}>Categories</a>
          <a href={`${base}archive/`}>Archive</a>
          <a href={`${base}search/`}>Search</a>
        </nav>
      </div>
    </header>
    <div class="container"><slot /></div>
  </body>
</html>
