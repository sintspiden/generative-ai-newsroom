---
const { title = 'Generative AI Newsroom' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <style>
      :root { --pill: #eef3ff; }
      body { background: #f6f8fb; }
      header { border-bottom: 1px solid #e6e8eb; background: white; position: sticky; top: 0; z-index: 10; }
      .header-inner { display: flex; gap: 1rem; justify-content: space-between; align-items: center; }
      nav { display: flex; gap: .8rem; flex-wrap: wrap; font-size: .95rem; }
      .brand { font-weight: 700; text-decoration: none; color: #111827; }
      .main { display: grid; gap: 1.25rem; grid-template-columns: 1fr; }
      .panel { background: #fff; border: 1px solid #e9eef5; border-radius: .9rem; padding: 1rem; box-shadow: 0 2px 10px rgba(15, 23, 42, .04); }
      .muted { color: #64748b; }
      .pill { display: inline-block; background: var(--pill); border: 1px solid #dbe6ff; border-radius: 999px; padding: .2rem .55rem; font-size: .78rem; margin-right: .4rem; }
      .tab-btn { border: 1px solid #d9e2f2; background: #fff; border-radius: 999px; padding: .35rem .8rem; font-size: .9rem; cursor: pointer; transition: all .18s ease; }
      .tab-btn:hover { border-color: #bdd0f7; background: #f7faff; }
      .tab-btn[aria-pressed='true'] { background: #e8f0ff; border-color: #b9ceff; font-weight: 600; color: #1d4ed8; }
      .feed { display: grid; gap: .85rem; }
      .item h3 { margin: .2rem 0 .4rem; font-size: 1.05rem; }
      .item p { margin: .35rem 0; }
      @media (min-width: 900px) { .main { grid-template-columns: 2.1fr .9fr; } }
    </style>
  </head>
  <body>
    <header>
      <div class="container header-inner">
        <a class="brand" href={`${base}`}>Generative AI Newsroom</a>
        <nav>
          <a href={`${base}#categories`}>Categories</a>
          <a href={`${base}archive/`}>Archive</a>
          <a href={`${base}search/`}>Search</a>
        </nav>
      </div>
    </header>
    <div class="container"><slot /></div>
  </body>
</html>
